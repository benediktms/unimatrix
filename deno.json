{
  "imports": {
    "@opencode-ai/plugin": "npm:@opencode-ai/plugin",
    "@modelcontextprotocol/sdk/server/mcp.js": "npm:@modelcontextprotocol/sdk@latest/server/mcp.js",
    "@modelcontextprotocol/sdk/server/stdio.js": "npm:@modelcontextprotocol/sdk@latest/server/stdio.js",
    "@std/assert": "jsr:@std/assert@^1",
    "zod": "npm:zod/v3"
  },
  "tasks": {
    "test:trimatrix": "deno test --allow-env --allow-read --allow-write --allow-run src/skills/trimatrix/",
    "lint:trimatrix": "deno lint src/skills/trimatrix/",
    "fmt:trimatrix": "deno fmt src/skills/trimatrix/",
    "check:trimatrix": "deno check src/skills/trimatrix/server.ts",
    "compile:trimatrix": "deno compile --allow-read --allow-env --allow-run --output bin/unimatrix src/skills/trimatrix/server.ts"
  },
  "compilerOptions": {
    "strict": true
  },
  "exclude": [
    "dist/",
    "bin/",
    ".venv/",
    ".opencode/",
    ".claude/",
    "__pycache__/"
  ]
}
