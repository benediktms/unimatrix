#!/usr/bin/env bash
# Post-commit: reinstall unimatrix and report result
REPO_DIR="$(git rev-parse --show-toplevel)"

if "$REPO_DIR/install.sh" --both --global > /dev/null 2>&1; then
  echo "Unimatrix: collective synchronized."
else
  echo "Unimatrix: synchronization failure. Manual intervention required." >&2
fi
