#!/usr/bin/env bash
# Auto-reinstall unimatrix after every commit
REPO_DIR="$(git rev-parse --show-toplevel)"
echo "⚡ Modification assimilated. Synchronizing collective installations..."
if "$REPO_DIR/install.sh" --both --global > /dev/null 2>&1; then
  echo "✓ Collective synchronized. All installations updated. The directive is fulfilled."
else
  echo "🔴 SYNCHRONIZATION FAILURE — Collective installation anomaly detected. Manual intervention required." >&2
fi
